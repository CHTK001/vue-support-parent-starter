{
  "name": "vue-support-parent-starter",
  "version": "1.1.0",
  "description": "",
  "packageManager": "pnpm@10.11.0",
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "node ./scripts/turbo-run/bin/turbo-run.mjs dev",
    "dev:iconify": "node ./scripts/iconify-run.mjs",
    "lint": "turbo lint",
    "build": "pnpm build:packages && pnpm build:apps",
    "build:packages": "node ./scripts/build-packages.mjs",
    "build:apps": "node ./scripts/build-apps.mjs",
    "build:app": "node ./scripts/build-apps.mjs --app",
    "build:doc": "turbo build --filter=docs",
    "clean": "node ./scripts/clean.mjs",
    "rmdist": "turbo rm dist",
    "nw:dev": "node ./scripts/nw-run.mjs dev",
    "nw:build": "node ./scripts/nw-run.mjs build",
    "install:safe": "node ./scripts/install-safe.js",
    "postinstall": "echo '✅ 依赖安装完成！如遇到 sharp 或 ttf2woff2 错误可忽略，不影响使用。'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
