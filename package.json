      "lodash.isequal": "*",
      "multiline": "*",
      "prebuild-install": "*",
      "xmldom": "*",
      "vue-i18n": "*"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "9",
        "vite": "7",
        "stylelint": "16"
      },
      "ignoreMissing": [
        "sharp",
        "onnxruntime-web"
      ]
    },
    "overrides": {
      "onnxruntime-web": ">=1.21.0"
    },
    "patchedDependencies": {},
    "onlyBuiltDependencies": [
      "protobufjs"
    ]
  }
