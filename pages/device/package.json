{
  "name": "@pages/device",
  "version": "1.0.0",
  "description": "设备管理模块",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm unbuild",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./simple": {
      "types": "./src/simple.ts",
      "default": "./src/simple.ts"
    },
    "./router/*": {
      "types": "./src/router/*.ts",
      "default": "./src/router/*.ts"
    },
    "./api/*": {
      "types": "./src/api/*.ts",
      "default": "./src/api/*.ts"
    },
    "./views/*": {
      "default": "./src/views/*"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "default": "./dist/index.mjs"
      },
      "./simple": {
        "default": "./dist/simple.mjs"
      },
      "./router/*": {
        "default": "./dist/router/*.mjs"
      },
      "./api/*": {
        "default": "./dist/api/*.mjs"
      },
      "./views/*": {
        "default": "./dist/views/*"
      }
    }
  },
  "dependencies": {
    "@pureadmin/utils": "catalog:",
    "@repo/components": "workspace:^",
    "element-plus": "catalog:",
    "hls.js": "catalog:",
    "js-base64": "catalog:",
    "unbuild": "catalog:",
    "vue": "catalog:",
    "vue-i18n": "catalog:",
    "vue-router": "catalog:",
    "@vueuse/core": "catalog:"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/types": "catalog:",
    "@repo/config": "workspace:^",
    "@repo/tailwind-config": "workspace:^",
    "@repo/tsconfig": "workspace:^",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "autoprefixer": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "postcss": "catalog:",
    "postcss-nesting": "catalog:",
    "prettier": "catalog:",
    "stylelint": "catalog:",
    "stylelint-config-html": "catalog:",
    "stylelint-config-recess-order": "catalog:",
    "stylelint-config-recommended-scss": "catalog:",
    "stylelint-config-recommended-vue": "catalog:",
    "stylelint-config-standard": "catalog:",
    "stylelint-config-standard-scss": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vue-tsc": "catalog:"
  }
}
