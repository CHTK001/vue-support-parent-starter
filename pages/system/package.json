{
  "name": "@pages/system",
  "version": "1.0.0",
  "description": "系统管理模块",
  "private": true,
  "keywords": [],
  "author": "CH",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "build": "pnpm unbuild",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./server-file-management": {
      "types": "./src/api/server-file-management.ts",
      "development": "./src/api/server-file-management.ts",
      "default": "./dist/api/server-file-management.mjs"
    },
    "./server-upload": {
      "types": "./src/api/server-upload.ts",
      "development": "./src/api/server-upload.ts",
      "default": "./dist/api/server-upload.mjs"
    },
    "./file-distribute": {
      "types": "./src/api/file-distribute.ts",
      "development": "./src/api/file-distribute.ts",
      "default": "./dist/api/file-distribute.mjs"
    },
    "./acme": {
      "types": "./src/api/acme.ts",
      "development": "./src/api/acme.ts",
      "default": "./dist/api/acme.mjs"
    },
    "./remote-desktop": {
      "types": "./src/api/remote-desktop.ts",
      "development": "./src/api/remote-desktop.ts",
      "default": "./dist/api/remote-desktop.mjs"
    },
    "./job": {
      "types": "./src/job/index.ts",
      "development": "./src/job/index.ts",
      "default": "./dist/job.mjs"
    },
    "./src/log/LogIndex.vue": {
      "default": "./src/log/LogIndex.vue"
    },
    "./src/log/LogDetail.vue": {
      "default": "./src/log/LogDetail.vue"
    },
    "./src/limit/LimitConfigurationIndex.vue": {
      "default": "./src/limit/LimitConfigurationIndex.vue"
    },
    "./src/limit/LimitRecordIndex.vue": {
      "default": "./src/limit/LimitRecordIndex.vue"
    },
    "./src/holiday/HolidayIndex.vue": {
      "default": "./src/holiday/HolidayIndex.vue"
    },
    "./src/holiday/HolidayCalendar.vue": {
      "default": "./src/holiday/HolidayCalendar.vue"
    },
    "./src/file/FileIndex.vue": {
      "default": "./src/file/FileIndex.vue"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "default": "./dist/index.mjs"
      },
      "./server-file-management": {
        "default": "./dist/api/server-file-management.mjs"
      },
      "./server-upload": {
        "default": "./dist/api/server-upload.mjs"
      },
      "./file-distribute": {
        "default": "./dist/api/file-distribute.mjs"
      },
      "./acme": {
        "default": "./dist/api/acme.mjs"
      },
      "./remote-desktop": {
        "default": "./dist/api/remote-desktop.mjs"
      }
    }
  },
  "dependencies": {
    "@repo/config": "workspace:^",
    "@pureadmin/utils": "catalog:",
    "@repo/components": "workspace:^",
    "@repo/utils": "workspace:^",
    "cropperjs": "catalog:",
    "element-plus": "catalog:",
    "lunisolar": "catalog:",
    "spark-md5": "catalog:",
    "unbuild": "catalog:",
    "vue": "catalog:",
    "vue-i18n": "catalog:",
    "vue-json-pretty": "catalog:"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/types": "catalog:",
    "@repo/tailwind-config": "workspace:^",
    "@repo/tsconfig": "workspace:^",
    "@types/node": "catalog:",
    "@types/spark-md5": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "autoprefixer": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "postcss": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
