{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "jsx": "preserve",
    "importHelpers": true,
    "experimentalDecorators": true,
    "strictFunctionTypes": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "baseUrl": ".",
    "allowJs": true,
    "resolveJsonModule": true,
    "lib": [
      "ESNext",
      "DOM",
      "ES2022"
    ],
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@pages/common": [
        "../../pages/common"
      ],
      "@pages/common/*": [
        "../../pages/common/*"
      ],
      "@build/*": [
        "build/*"
      ],
      "@repo/components/*": [
        "../../packages/components/*"
      ],
      "@repo/components": [
        "../../packages/components"
      ],
      "@repo/config": [
        "../../packages/config"
      ],
      "@repo/core": [
        "../../packages/core"
      ],
      "@repo/utils": [
        "../../packages/utils"
      ],
      "@repo/plugins": [
        "../../packages/plugins"
      ],
      "@layout/default": [
        "../../layout/default/src"
      ]
    },
    "types": [
      "node",
      "vite/client",
      "element-plus/global"
    ]
  },
  "include": [
    "env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "vite.config.ts"
  ],
  "exclude": [
    "dist",
    "**/*.js",
    "node_modules",
    "**/node_modules/**",
    "**/dist/**",
    "**/.turbo/**"
  ]
}