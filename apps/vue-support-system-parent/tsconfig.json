{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "jsx": "preserve",
    "importHelpers": true,
    "experimentalDecorators": true,
    "strictFunctionTypes": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "baseUrl": ".",
    "allowJs": true,
    "resolveJsonModule": true,
    "lib": [
      "ESNext",
      "DOM",
      "ES2022"
    ],
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@build/*": [
        "build/*"
      ],
      "@repo/codec-wasm": [
        "../../packages/codec-wasm/src/index.js"
      ],
      "@pages/common": [
        "../../pages/common"
      ],
      "@pages/common/*": [
        "../../pages/common/*"
      ],
      "@repo/components/*": [
        "../../packages/components/*"
      ],
      "@repo/components": [
        "../../packages/components"
      ],
      "@repo/config": [
        "../../packages/config"
      ],
      "@repo/core": [
        "../../packages/core"
      ],
      "@repo/utils": [
        "../../packages/utils"
      ],
      "@repo/plugins": [
        "../../packages/plugins"
      ],
      "@layout/default": [
        "../../layout/default/src"
      ]
    },
    "types": [
      "node",
      "vite/client",
      "element-plus/global",
      "@pureadmin/table/volar",
      "@pureadmin/descriptions/volar"
    ]
  },
  "include": [
    "env.d.ts",
    "@repo/core",
    "src/types/*.d.ts",
    "../../packages/types/*.d.ts",
    "mock/*.ts",
    "**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "vite.config.ts",
    "../../packages/core/src/api/common/sms.ts",
    "src/views/manage/template/camera/camera.vue",
    "src/views/ai/llm/chat copy.11",
    "src/views/manage/template/device/preview/camera-preview copy.1",
    "src/views/manage/dept/index.vue1"
  ],
  "exclude": [
    "dist",
    "**/*.js",
    "node_modules",
    "**/node_modules/**",
    "**/dist/**",
    "**/.turbo/**"
  ]
}