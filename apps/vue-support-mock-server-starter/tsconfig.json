{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@repo/components/*": [
        "../../packages/components/*"
      ],
      "@repo/components": [
        "../../packages/components"
      ],
      "@repo/config": [
        "../../packages/config"
      ],
      "@repo/core": [
        "../../packages/core"
      ],
      "@repo/utils": [
        "../../packages/utils"
      ],
      "@repo/plugins": [
        "../../packages/plugins"
      ],
      "@layout/default": [
        "../../layout/default/src"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}