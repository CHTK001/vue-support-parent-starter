{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/tsconfig/web.json",
  "include": [
    "**/*.ts",
    "**/*.vue",
    "src/types/*.d.ts",
    "hooks/*.d.ts",
    "mock/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "vite.config.ts"
  ],
  "exclude": [
    "dist",
    "**/*.js",
    "node_modules",
    "**/node_modules/**",
    "**/dist/**",
    "**/.turbo/**"
  ],
  "compilerOptions": {
    "paths": {
      "@repo/components/*": [
        "../../packages/components/*"
      ],
      "@repo/components": [
        "../../packages/components"
      ],
      "@repo/config": [
        "../../packages/config"
      ],
      "@repo/core": [
        "../../packages/core"
      ],
      "@repo/utils": [
        "../../packages/utils"
      ],
      "@repo/plugins": [
        "../../packages/plugins"
      ],
      "@layout/default": [
        "../../layout/default/src"
      ]
    }
  }
}